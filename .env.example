# Resource Management
MAX_MEMORY_PERCENT=80.0
MAX_CPU_PERCENT=70.0
MAX_PROCESSES=100

# Rate Limiting
MAX_REQUESTS_PER_WINDOW=100
WINDOW_SECONDS=900

# Feature Flags
ENABLE_NLP_OPTIMIZATION=true
ENABLE_REAL_TIME_MONITORING=true
ENABLE_RATE_LIMITING=true
ENABLE_HEARTBEAT=true
ENABLE_RESOURCE_MONITORING=true
USE_BROWSER_AUTOMATION=false
BROWSER_AUTO_RETRY=true

# Browser Automation Settings
BROWSER_SESSION_DURATION=3600
BROWSER_COOKIE_ENCRYPTION_KEY=your_secure_key_here
BROWSER_COOKIE_DIR=~/.twitter_cookies

# Proxy Configuration
BROWSER_USE_PROXY=false
BROWSER_PROXY_HOST=
BROWSER_PROXY_PORT=
BROWSER_PROXY_USERNAME=
BROWSER_PROXY_PASSWORD=
BROWSER_PROXY_HEALTH_CHECK_TIMEOUT=10

# Twitter Authentication
TWITTER_EMAIL=                 # Account email for verification
TWITTER_API_KEY=              # Twitter API Key
TWITTER_API_SECRET_KEY=       # Twitter API Secret Key
TWITTER_ACCESS_TOKEN=         # Access Token for Twitter API v2
TWITTER_ACCESS_TOKEN_SECRET=  # Access Token Secret for Twitter API v2

# Security
ENCRYPTION_KEY=your_encryption_key_here

# Twitter API Configuration
# Add accounts for each character (1, 2, 3, etc.)

# Host Account (Required)
TWITTER_ACCOUNT_1_CHARACTER=Host
TWITTER_ACCOUNT_1_API_KEY=your_api_key_here
TWITTER_ACCOUNT_1_API_SECRET=your_api_secret_here
TWITTER_ACCOUNT_1_ACCESS_TOKEN=your_access_token_here
TWITTER_ACCOUNT_1_ACCESS_TOKEN_SECRET=your_access_token_secret_here

# Character Account Examples
TWITTER_ACCOUNT_2_CHARACTER=Alice
TWITTER_ACCOUNT_2_API_KEY=your_api_key_here
TWITTER_ACCOUNT_2_API_SECRET=your_api_secret_here
TWITTER_ACCOUNT_2_ACCESS_TOKEN=your_access_token_here
TWITTER_ACCOUNT_2_ACCESS_TOKEN_SECRET=your_access_token_secret_here

TWITTER_ACCOUNT_3_CHARACTER=Bob
TWITTER_ACCOUNT_3_API_KEY=your_api_key_here
TWITTER_ACCOUNT_3_API_SECRET=your_api_secret_here
TWITTER_ACCOUNT_3_ACCESS_TOKEN=your_access_token_here
TWITTER_ACCOUNT_3_ACCESS_TOKEN_SECRET=your_access_token_secret_here

# Twitter Browser Automation Configuration
# Add browser accounts for each character (1, 2, 3, etc.)

# Host Browser Account (Required when USE_BROWSER_AUTOMATION=true)
TWITTER_BROWSER_1_CHARACTER=Host
TWITTER_BROWSER_1_USERNAME=your_username_here
TWITTER_BROWSER_1_PASSWORD=your_password_here

# Character Browser Account Examples
TWITTER_BROWSER_2_CHARACTER=Alice
TWITTER_BROWSER_2_USERNAME=your_username_here
TWITTER_BROWSER_2_PASSWORD=your_password_here

TWITTER_BROWSER_3_CHARACTER=Bob
TWITTER_BROWSER_3_USERNAME=your_username_here
TWITTER_BROWSER_3_PASSWORD=your_password_here

# ElevenLabs Configuration
ELEVENLABS_API_KEY=your_elevenlabs_api_key_here
